parameters:
    level: 5
    parallel:
        maximumNumberOfProcesses: 1
    paths:
        - luwipress/
    excludePaths:
        - luwipress/assets/
        - luwipress/languages/
    bootstrapFiles:
        - phpstan-bootstrap.php
    ignoreErrors:
        # Rank Math is an optional third-party plugin (not in our autoload or
        # stubs). The Redirections bridge (FR-042) guards every call with
        # class_exists() and degrades to a 503 when RM is absent, so these
        # "unknown class" reports are an expected external-dependency boundary.
        -
            message: '#on an unknown class RankMath#'
            path: luwipress/includes/class-luwipress-redirections.php
        # UpdraftPlus is an optional third-party plugin (not in our autoload or
        # stubs). The Backup Bridge guards every call with is_a()/class_exists()
        # and the method_exists() probes are deliberate version-drift defenses;
        # PHPStan can't see the (real) static methods on the unknown class, so it
        # reports the literal-class method_exists() as "always false". Expected
        # external-dependency boundary, same as the Rank Math case above.
        -
            message: '#Call to function method_exists\(\) with .*UpdraftPlus.* will always evaluate to false#'
            path: luwipress/includes/class-luwipress-backup-bridge.php
    # All existing errors tracked in phpstan-baseline.neon
    # New code must pass Level 5 clean

includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - phpstan-baseline.neon
