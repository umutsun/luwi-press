    },
    "settings": {
        "timezone": "Europe/Istanbul",
        "saveManualExecutions": true,
        "executionOrder": "v1",
        "errorWorkflow": "7Pv7BtdURlzf9HsZ"
    },
    "meta": {
        "description": "Receives WooCommerce product via webhook, generates SEO-optimized content (description, meta, FAQ, schema, alt text) with Claude AI, sends results back via callback. All config via _meta block from WordPress.",
