        ]
      ]
    },
    "Rating >= 4?": {
      "main": [
        [{ "node": "Auto-Publish Reply", "type": "main", "index": 0 }],
        [{ "node": "Queue Reply for Approval", "type": "main", "index": 0 }]
      ]
    },
    "Auto-Publish Reply": {
      "main": [
        [{ "node": "Action Log", "type": "main", "index": 0 }]
      ]
    },
    "Queue Reply for Approval": {
      "main": [
        [{ "node": "Send Low Rating Alert", "type": "main", "index": 0 }]
      ]
    },
    "Send Low Rating Alert": {
      "main": [
        [{ "node": "Action Log", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "timezone": "Europe/Istanbul",
    "saveManualExecutions": true,
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Checks WooCommerce reviews every 6 hours, generates replies via Claude AI + sentiment analysis. Rating >= 4 auto-publishes, low ratings queued for approval with admin alert. Sentiment data sent to n8nPress Review Analytics.",
    "required_env": ["WP_SITE_URL"],
    "required_credentials": ["wooCommerceApi"],
    "workflow_flow": "Schedule (6h) → Site Config → Fetch Reviews → Filter Unanswered → Batch(5) → Claude AI → Process Reply → [Rating Check + Sentiment Callback] → Auto-publish / Queue + Alert"
  }
}